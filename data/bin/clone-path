#! /bin/sh

if [ $# -lt 2 ]; then
    echo "Usage: $0 [RSYNC_OPTION ...] SRC DEST" >&2
    echo 'Noteworthy additional rsync options:' >&2
    echo '  --exclude=PATTERN --human-readable --itemize-changes --no-motd --progress --quiet --stats' >&2
    exit 1
fi

# Not supported: --crtimes
rsync --acls --archive --atimes --delete --hard-links --numeric-ids --open-noatime --sparse --super --xattrs "$@"
