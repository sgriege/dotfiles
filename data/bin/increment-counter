#! /bin/sh

# Check number of command line arguments.
if [ $# -ne 1 ]; then
    echo "Usage: $0 FILE" >&2
    exit 1
fi

# Check whether the file exists.
if [ ! -f $1 ]; then
    echo "Error: \"$1\" does not exist or is not a regular file" >&2
    exit 1
fi

# Read the counter's current value, increment it and write the new value.
read counter < "$1"
let counter=$counter+1
echo $counter > "$1"
