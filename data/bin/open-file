#! /bin/sh

# Check number of command line arguments.
if [ $# -ne 1 ]; then
    echo "Usage: $0 FILE" >&2
    exit 1
fi

file=$1

# Check whether the file is regular.
if [ ! -f "$file" ]; then
    echo "\"$file\" does not exist or is not a regular file" >&2
    exit 1
fi

# Open the file.
silence xdg-open "$file"
