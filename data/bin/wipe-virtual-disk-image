#! /bin/sh

# Check number of command line arguments.
if [ $# -ne 1 ]; then
    echo "Usage: $0 VDI" >&2
    exit 1
fi

vdi=$1

# Retrieve size in MB.
size_mb=`VBoxManage showmediuminfo "$vdi" | sed '/^Capacity/{s/^Capacity:[[:space:]]*\([[:digit:]]*\)[[:space:]]*MBytes$/\1/; q}; d'`
[ $? -ne 0 -o -z "$size_mb" ] && exit 1

# Create temporary directory for the blank VDI.
tmp=`mktemp --directory --tmpdir=/tmp blank-vdi-XXXXXXXXXX`
blank_vdi="$tmp/blank.vdi"

# Create blank VDI.
VBoxManage createmedium --filename="$blank_vdi" --size="$size_mb"
status=$?

# Wipe and compact the desired VDI.
if [ $status -eq 0 ]; then
    VBoxManage clonemedium "$blank_vdi" "$vdi" --existing \
        && VBoxManage modifymedium "$vdi" --compact
    status=$?
fi

# Do cleanup.
[ -e "$blank_vdi" ] && VBoxManage closemedium "$blank_vdi" --delete
rm -f "$blank_vdi"
rmdir "$tmp"
exit $status
